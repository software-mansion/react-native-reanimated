{
  "compilerOptions": {
    "baseUrl": ".",
    "target": "es6",
    "module": "nodenext",
    "skipLibCheck": true,
    "moduleResolution": "nodenext",
    "esModuleInterop": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "allowJs": true,
    "checkJs": true,
    "noEmit": true
  },
  "include": ["."]
}
