    "lint:clang-tidy": ":",
    "lint:js": ":",
    "lint:plugin": ":",
    "test": ":",
    "type:check": ":",
    "type:check:src:native": ":",
    "type:check:src:web": ":",
    "type:check:app": ":",
    "type:check:plugin": ":",
    "type:check:tests": ":",
    "tree-shake:check:web": ":"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/software-mansion/react-native-reanimated.git",
