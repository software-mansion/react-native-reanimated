{
  "name": "web-example",
  "main": "index.js",
  "private": true,
  "version": "0.0.1",
  "scripts": {
    "start": "expo start --web",
    "start:noplugin": "DISABLE_BABEL_PLUGIN=1 yarn start",
    "production": "yarn expo export -p web && yarn serve dist --single",
    "format": "yarn run --top-level oxfmt .",
    "build": "",
    "lint": "eslint . --max-warnings 0",
    "type:check": "tsc --noEmit",
    "test:e2e": "node scripts/run-e2e.mjs",
    "test:e2e:ui": "node scripts/run-e2e.mjs --ui",
    "test:e2e:headed": "node scripts/run-e2e.mjs --headed"
  },
  "dependencies": {
    "common-app": "workspace:*",
    "expo": "56.0.12",
    "hermes-parser": "0.36.1",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.87.0-rc.0",
    "react-native-web": "0.21.2",
    "react-strict-dom": "0.0.54"
  },
  "devDependencies": {
    "@expo/metro-runtime": "56.0.15",
    "@playwright/test": "1.57.0",
    "@types/react": "19.2.2",
    "babel-preset-expo": "56.0.15",
    "eslint": "9.37.0",
    "serve": "14.2.5",
    "typescript": "5.9.3"
  },
  "installConfig": {
    "selfReferences": false
  }
}
