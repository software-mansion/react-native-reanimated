{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "bracketSameLine": true,
  "printWidth": 80,
  "singleQuote": true,
  "trailingComma": "es5",
  "tabWidth": 2,
  "arrowParens": "always",
  "sortPackageJson": false,
  "jsdoc": true,
  "ignorePatterns": [
    "build/",
    ".yarn/",
    "*.md",
    "*.mdx",
    "packages/react-native-worklets/plugin/lib/",
    "packages/react-native-worklets/plugin/index.js",
    "packages/react-native-worklets/plugin/index.js.map",
    "ios/",
    "macos/",
    "vendor/",
    "apps/common-app/**/*.snapshot.ts",
    "docs/**/build/",
    "docs/**/.docusaurus/"
  ],
  "overrides": [
    {
      "files": ["packages/react-native-worklets/src/types.ts"],
      "options": {
        "jsdoc": false
      }
    }
  ]
}
